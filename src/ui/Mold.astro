---
import HomeScreen from "./screens/HomeScreen.astro";
import SpeedrunScreen from "./screens/challenge-screens/SpeedrunScreen.astro"; // Serves as the Universal Challenge Screen
import PracticeScreen from "./screens/practice-screens/PracticeScreen.astro";
import FlashcardScreen from "./screens/practice-screens/FlashcardScreen.astro";
import ResultsScreen from "./screens/ResultsScreen.astro";
import RevisionScreen from "./screens/RevisionScreen.astro";
import AchievementsScreen from "./screens/AchievementsScreen.astro";

import type { SubjectData } from "../data/subjects/Subject";

interface Props {
    subject: SubjectData;
}

const { subject } = Astro.props;
---

<div
    id="loading-overlay"
    style="position: fixed; inset: 0; background: #000; color: #fff; display: flex; align-items: center; justify-content: center; z-index: 9999;"
>
    <div>
        <h2>Loading Assets...</h2>
        <p id="loading-status">Synchronizing subject data</p>
    </div>
</div>

<div class="mold-container" style="display: none;" id="game-container">
    <HomeScreen
        subjectName={subject.name}
        description={subject.config.description}
    />

    <!-- Consolidated Challenge Mode Screen -->
    <SpeedrunScreen />

    <!-- Practice Modes -->
    <PracticeScreen />
    <FlashcardScreen />

    <!-- Utility Screens -->
    <ResultsScreen />
    <RevisionScreen />
    <AchievementsScreen />

    <div class="combo-popup" id="comboPopup">
        <div class="combo-text" id="comboText"></div>
    </div>
</div>

<script>
    import { subjectState } from "../logic/state/SubjectState";

    import { Subject } from "../logic/entities/Subject";
    import { migrationService } from "../infrastructure/db/MigrationService";
    import { eventBus } from "../infrastructure/events/EventBus";

    // Pass subject data from SSR to client logic
    const subjectData = subjectState.getSubject();

    async function initAssets() {
        const statusEl = document.getElementById("loading-status");
        if (!subjectData) {
            console.error("No subject data found!");
            if (statusEl) statusEl.textContent = "Error: Missing Subject Data";
            return;
        }

        try {
            // Step 1: Run localStorage migration if needed
            if (statusEl)
                statusEl.textContent = "Checking for data migration...";
            const migrationComplete =
                await migrationService.isMigrationComplete();

            if (!migrationComplete) {
                if (statusEl)
                    statusEl.textContent =
                        "Migrating localStorage data to database...";
                await migrationService.migrate();
            }

            // Step 2: Instantiate subject with ID from SSR
            const subject = new Subject(subjectData.id, subjectData.name);

            if (statusEl) statusEl.textContent = `Syncing ${subject.name}...`;

            // Step 3: Perform Sync (API -> DB if missing)
            await eventBus.emit("data:sync-start", { syncType: "subjects" });
            const success = await subject.sync();

            if (success) {
                // Step 4: Load Data into Memory (and subjectState.getSubject() for legacy screens)
                await subject.loadFromDB();

                await eventBus.emit("data:sync-complete", {
                    syncType: "subjects",
                    itemsProcessed: 1,
                });

                // Step 5: Emit database ready event
                await eventBus.emit("database:ready", {
                    hasExistingData: true,
                });

                // Step 6: Hide loader, show game
                const overlay = document.getElementById("loading-overlay");
                const container = document.getElementById("game-container");
                if (overlay) overlay.style.display = "none";
                if (container) container.style.display = "block";
                console.log("[Mold] Assets loaded and synced successfully.");

                // Legacy event for backward compatibility (will be removed)
                window.dispatchEvent(
                    new CustomEvent("game-assets-ready", {
                        detail: subjectState.getSubject(),
                    }),
                );
            } else {
                if (statusEl)
                    statusEl.textContent =
                        "Failed to sync assets. Are you online?";
            }
        } catch (e) {
            console.error("[Mold] Asset load error:", e);
            if (statusEl)
                statusEl.textContent = "Critical Error loading assets.";
        }
    }

    // Wait for window load or just run
    window.addEventListener("load", initAssets);
</script>

<script is:inline define:vars={{ subject }}>
    subjectState.setSubject(subject);
</script>
