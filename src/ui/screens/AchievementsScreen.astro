---
---
<div class="screen" id="achievementsScreen">
    <div class="header">
        <h1>🏆 Achievements</h1>
        <!-- <p id="achievementStats">0 / 30 Unlocked</p> -->
    </div>
    <div class="container">
        <div id="achievementsList" class="achievements-grid"></div>
        <button class="btn btn-secondary" onclick="window.game.goHome()" style="margin-top:20px">
            ← Back to Home
        </button>
    </div>
</div>


<script>
    import { AchievementRepository } from "../../infrastructure/db/repositories/AchievementRepository";
    import { PlayerRepository } from "../../infrastructure/db/repositories/PlayerRepository";
    import { uiStore } from "../../logic/state/UIStore";

    interface SubjectData {
        id: string;
        name: string;
        achievements?: any[];
    }

    class AchievementsScreenController {
        private subject: SubjectData;
        private currentPlayerId: number = 1;

        constructor() {
            // @ts-ignore
            this.subject = window.subjectData;
            this.loadCurrentPlayer();
            this.bindEvents();
        }

        async loadCurrentPlayer() {
            const playerRepo = PlayerRepository.getInstance();
            let player = await playerRepo.getPlayerByName('Default Player');
            
            if (!player) {
                player = await playerRepo.createPlayer('Default Player');
            }
            
            this.currentPlayerId = player.id;
        }

        bindEvents() {
             // @ts-ignore
            window.game = window.game || {};
            // @ts-ignore
            window.game.showAchievements = this.show.bind(this);
        }

        async show() {
            this.showScreen('achievementsScreen');
            await this.render();
        }

        showScreen(id: string) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id)?.classList.add('active');
        }

        async render(): Promise<void> {
            const achievementRepo = AchievementRepository.getInstance();
            const grid = document.getElementById('achievementsList');

            if (!grid) return;

            // Get all achievements for this subject
            const allAchievements = await achievementRepo.getAchievementsBySubject(this.subject.id);
            
            // Get player's unlocked achievements
            const unlockedAchievements = await achievementRepo.getPlayerAchievements(this.currentPlayerId);
            const unlockedIds = unlockedAchievements.map(a => a.achievementId);

            if (allAchievements.length === 0) {
                grid.innerHTML = '<p class="empty-message">No achievements available for this subject.</p>';
                return;
            }

            grid.innerHTML = allAchievements.map(ach => {
                const isUnlocked = unlockedIds.includes(ach.id);
                return `
                    <div class="achievement-card ${isUnlocked ? 'unlocked' : 'locked'}">
                        <div class="achievement-icon">${ach.icon || '🏆'}</div>
                        <div class="achievement-info">
                            <h3>${ach.title}</h3>
                            <p>${ach.description}</p>
                        </div>
                    </div>
                `;
            }).join('');
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        new AchievementsScreenController();
    });
</script>
