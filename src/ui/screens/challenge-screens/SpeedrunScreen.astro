---
import GameHeader from '../../components/GameHeader.astro';
import QuestionContainer from '../../components/gameplay/QuestionContainer.astro';
import GameFooter from '../../components/GameFooter.astro';
import HintPopup from '../../components/HintPopup.astro';
import StreakCounter from '../../components/modules/StreakCounter.astro';
import '../../../styles/screens/speedrun.css';
---

<div class="screen speedrun-screen" id="speedrun-screen">
    <div class="screen-wrapper">
        <GameHeader mode="challenge" id="sr-header" />
        
        <div class="sr-content">
            <!-- Question Container wraps Display + StressBar logic -->
            <QuestionContainer id="sr-question-container" enableStressBar={true} />
        </div>
    
        <GameFooter id="sr-footer" />
        <HintPopup id="sr-hint-popup" />
        
        <!-- Module: Streak Counter -->
        <StreakCounter id="sr-streak" />
    </div>
</div>

<script>
    import { subjectState } from "../../../logic/state/SubjectState";

    import { GameEngine } from "../../../logic/controllers/GameEngine";
    import { Subject } from "../../../logic/entities/Subject";
    import { Player } from "../../../logic/entities/Player";
    import { BaseScreenController } from "../../controllers/BaseScreenController";
    import { eventBus } from "../../../infrastructure/events/EventBus";
    import { componentRegistry } from "../../registry/ComponentRegistry";

    /**
     * ChallengeGameController - Refactored to use BaseScreenController
     * 
     * Improvements:
     * - Extends BaseScreenController for proper lifecycle
     * - Uses componentRegistry instead of polling
     * - Uses eventBus instead of window events
     * - No direct window.game pollution
     */
    class ChallengeGameController extends BaseScreenController {
        private engine: GameEngine | null = null;
        private header: any;
        private footer: any;
        private container: any;
        private streakModule: any;
        
        private isAnswered: boolean = false;
        private currentSelection: any = null;
        private config: any = {};

        constructor() {
            super('speedrun-screen');
        }

        /**
         * Lifecycle: Called after screen is mounted and DOM is ready
         */
        async onInit(): Promise<void> {
            console.log("[SpeedrunScreen] Initializing...");
            
            // Get components from registry instead of polling
            this.header = componentRegistry.get('sr-header');
            this.footer = componentRegistry.get('sr-footer');
            this.container = componentRegistry.get('sr-question-container');
            this.streakModule = componentRegistry.get('sr-streak');

            if (!this.header || !this.footer || !this.container) {
                console.error("[SpeedrunScreen] Required components not found in registry");
                return;
            }

            // Subscribe to events
            this.subscribeToEvents();
            
            // Register screen methods
            this.registerMethods();
            
            console.log("[SpeedrunScreen] Ready");
        }
        
        /**
         * Subscribe to game events using eventBus
         */
        subscribeToEvents() {
            const screen = this.getScreenElement();
            if (!screen) return;

            // DOM events (from components)
            screen.addEventListener('request-submit', () => this.submitAnswer());
            screen.addEventListener('request-next', () => this.nextQuestion());
            screen.addEventListener('request-skip', () => this.handleSkip());
            screen.addEventListener('question-selected', (e: any) => this.handleSelection(e.detail));
            screen.addEventListener('time-up', (e: any) => this.handleTimeEvent(e));

            // Event bus subscriptions
            eventBus.on('answer:submitted', (data) => {
                console.log("[SpeedrunScreen] Answer submitted:", data.isCorrect);
            });

            eventBus.on('game:complete', async (data) => {
                console.log("[SpeedrunScreen] Game complete:", data);
                await this.finishGame();
            });

            eventBus.on('game:stats-update', (data) => {
                // Update UI with stats
                if (this.header) {
                    this.header.setScore(data.score);
                }
            });
        }

        /**
         * Register methods to componentRegistry instead of window.game
         */
        registerMethods() {
            componentRegistry.register('speedrun-controller', {
                start: () => this.startChallenge(),
                screen: this.screenId,
            });
            
            // For backward compatibility, also register on window.game
            // TODO: Remove this once HomeScreen is updated
            // @ts-ignore
            window.game = window.game || {};
            // @ts-ignore
            window.game.startSpeedrun = this.startChallenge.bind(this);
            // @ts-ignore
            window.game.startBlitz = this.startChallenge.bind(this);
        }

        async startChallenge() {
            console.log("[SpeedrunScreen] Starting challenge...");
            this.show();
            
            // 1. Get config from settings panel
            // @ts-ignore
            this.config = (window as any).getGameConfig ? (window as any).getGameConfig() : { 
                isSurvival: false, 
                timeLimitSeconds: 0,
                difficulty: 'medium',
                timeLimit: 0,
            };
            
            // 2. Load subject data
            // @ts-ignore
            const subjectData = subjectState.getSubject();
            const subject = new Subject(subjectData.id, subjectData.name);
            await subject.loadFromDB();
            
            // 3. Get or create player
            const player = await Player.create("Default Player");  

            // 4. Create engine with new API (no callback)
            this.engine = new GameEngine(
                subject, 
                player,
                { 
                    mode: 'speedrun',
                    subjectId: subject.id, 
                    modeType: 'challenge', 
                    settings: this.config 
                }
            );
            
            // 5. Start game
            await this.engine.start();
            
            // 6. Render initial state
            this.renderState(this.engine.getState());
            
            // 7. Start header timer
            if (this.header && this.config.timeLimitSeconds) {
                this.header.startTimer(this.config.timeLimitSeconds);
            }
            
            console.log("[SpeedrunScreen] Challenge started");
        }

        activateScreen() {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById('speedrun-screen')?.classList.add('active');
        }

        renderState(state: any) {
            console.log("[SpeedrunScreen] Rendering state:", state.status);
            
            // Check if game is complete
            if (state.status === 'COMPLETED') {
                return this.finishGame();
            }
            
            this.isAnswered = state.isAnswered || false;
            this.currentSelection = null;
            
            // 1. Render question
            if (this.container && state.currentQuestion) {
                this.container.render(state.currentQuestion);
                this.container.enableStressBar(this.config.isSurvival);
                
                if (this.config.isSurvival) {
                    this.container.startStressTimer(15);
                } else {
                    this.container.stopStressTimer();
                }
            }

            // 2. Update header score
            if (this.header) {
                this.header.setScore(state.stats.score);
            }
            
            // 3. Show streak feedback (every 5)
            if (state.stats.streak > 0 && state.stats.streak % 5 === 0 && this.streakModule) {
                this.streakModule.show(state.stats.streak);
            }

            // 4. Update footer
            if (this.footer) {
                if (state.status === 'FEEDBACK') {
                    this.footer.showNext();
                } else {
                    this.footer.showSubmit();
                    this.footer.enableSubmit(false);
                }
            }
        }
        
        handleSelection(detail: any) {
            if (this.isAnswered) return;
            this.currentSelection = detail;
            if(this.footer) this.footer.enableSubmit(true);
        }

        submitAnswer() {
            if (!this.engine) {
                console.warn("[SpeedrunScreen] Cannot submit: engine not initialized");
                return;
            }

            if (this.isAnswered || !this.currentSelection) {
                console.warn("[SpeedrunScreen] Submit ignored", { 
                    isAnswered: this.isAnswered, 
                    hasSelection: !!this.currentSelection 
                });
                return;
            }

            console.log("[SpeedrunScreen] Submitting answer...");
            this.processResult();
        }

        handleSkip() {
            if (!this.engine || this.isAnswered) return;
            
            console.log("[SpeedrunScreen] Skipping question");
            this.currentSelection = null;
            this.isAnswered = true;
            
            // Stop timer and show feedback
            if (this.container) {
                this.container.stopStressTimer();
                this.container.showFeedback(false);
                this.container.reveal();
            }
            
            // Submit as incorrect
            const state = this.engine.getState();
            this.engine.submitAnswer(null, state.currentQuestion?.correctAnswer, false);
            
            // Show next button
            if (this.footer) {
                this.footer.showNext("Next");
            }
        }

        async processResult() {
            if (!this.container || !this.engine) return;
            
            this.container.stopStressTimer();
            const isCorrect = this.container.reveal();
            this.container.showFeedback(isCorrect);
            
            const state = this.engine.getState();
            
            // Submit answer to engine
            await this.engine.submitAnswer(
                this.currentSelection,
                state.currentQuestion?.correctAnswer,
                isCorrect
            );
            
            // Update state and show next button
            this.renderState(this.engine.getState());
        }

        async nextQuestion() {
            if (!this.engine) return;
            
            console.log("[SpeedrunScreen] Loading next question");
            await this.engine.nextQuestion();
            this.renderState(this.engine.getState());
        }

        handleTimeEvent(e: any) {
            const targetId = (e.target as HTMLElement).id;
            
            if (targetId.includes('stopwatch')) {
                // Global time limit reached
                console.log("[SpeedrunScreen] Global time limit reached");
                if (this.engine) {
                    this.engine.endGame();
                }
            } else {
                // Per-question time limit (stress bar)
                console.log("[SpeedrunScreen] Question time limit reached");
                this.handleSkip();
            }
        }
        
        async finishGame() {
            if (!this.engine) return;
            
            console.log("[SpeedrunScreen] Finishing game");
            
            // Stop all timers
            if (this.header) this.header.stopTimer();
            if (this.container) this.container.stopStressTimer();
            
            const state = this.engine.getState();
            
            // Show results screen
            // @ts-ignore
            if (window.game.showResults) {
                // @ts-ignore
                window.game.showResults({
                    score: state.stats.correct,
                    total: state.stats.totalQuestions,
                    time: state.stats.endTime ? 
                        (state.stats.endTime - state.stats.startTime) / 1000 : 0,
                    answers: [],
                    maxStreak: state.stats.streak,
                    mode: 'speedrun'
                });
            }
        }

        /**
         * Lifecycle: Cleanup on unmount
         */
        async onDestroy(): Promise<void> {
            if (this.engine) {
                this.engine.destroy();
            }
            console.log("[SpeedrunScreen] Destroyed");
        }
    }

    new ChallengeGameController();
</script>
